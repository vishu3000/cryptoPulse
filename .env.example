# Root: copy this to apps/api/.env and fill in values
DATABASE_URL=postgresql://cryptopulse:cryptopulse@localhost:5432/cryptopulse
PORT=4000
WEB_ORIGIN=http://localhost:3000
NODE_ENV=development
DEV_USER_ID=dev-user-001

# Auth — register CryptoPulse tenant in vi-auth-sdk to get these
AUTH_PUBLISHABLE_KEY=pk_test_...
AUTH_SECRET_KEY=sk_test_...

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=alerts@cryptopulse.dev
